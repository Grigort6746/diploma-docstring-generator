# ==============================
# Operating system files
# ==============================

.DS_Store
Thumbs.db
desktop.ini

# ==============================
# Editors and IDEs
# ==============================

.idea/
*.sublime-project
*.sublime-workspace

# Keep useful VS Code project files if needed.
# Do not ignore the whole .vscode folder globally,
# because extension debugging configs may be useful.
.vscode/*
!.vscode/settings.json
!.vscode/launch.json
!.vscode/tasks.json
!.vscode/extensions.json

# ==============================
# Environment variables and secrets
# ==============================

.env
.env.*
*.env
secrets.*
*.secret
*.key
*.pem
*.token

# ==============================
# Node.js / VS Code extension
# ==============================

node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# VS Code extension compiled output
out/
dist/
build/

# Packaged VS Code extensions
*.vsix

# Test coverage
coverage/
.nyc_output/

# ==============================
# TypeScript / JavaScript caches
# ==============================

*.tsbuildinfo
.eslintcache

# ==============================
# Python
# ==============================

__pycache__/
*.py[cod]
*$py.class

.venv/
venv/
env/
ENV/

.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/

# ==============================
# ML / datasets / model artifacts
# ==============================

# Large datasets
*.parquet
*.arrow
*.jsonl
*.csv
*.tsv

# Large model files
*.gguf
*.bin
*.safetensors
*.pt
*.pth
*.ckpt
*.onnx

# LoRA / Hugging Face checkpoints
checkpoint-*/
checkpoints/
runs/
wandb/
mlruns/

# Local model folders
models/
model/
merged_model/
qwen-docstring-clean-fp16/
qwen-docstring-merged/
qwen-docstring-final/

# Ollama local model artifacts
ollama/*.gguf

# ==============================
# Data folders
# ==============================

data/raw/
data/interim/
data/processed/
data/cache/
data/*.parquet
data/*.jsonl
data/*.csv

# Keep small examples if explicitly needed
!data/examples/
!data/examples/**

# ==============================
# Logs and temporary files
# ==============================

*.log
logs/
tmp/
temp/
.cache/

# ==============================
# Archives
# ==============================

*.zip
*.tar
*.tar.gz
*.7z
*.rar

# ==============================
# Documents generated from diploma work
# ==============================

# Keep source docs, ignore temporary office lock files
~$*.doc
~$*.docx
~$*.pptx
~$*.xlsx

# Optional: uncomment if generated PDFs should not be tracked
# *.pdf